---
import type { Product } from "../data/products";
import { cop } from "../consts";
interface Props {
  product: Product;
}
const { product } = Astro.props;
---
<div class="card p-5">
  <h2 class="font-head text-xl font-bold">Precios y tamaños</h2>
  <p class="mt-1 text-sm text-[var(--color-ink-soft)]">
    Precios "desde". Cada pieza se pinta a mano.
  </p>
  <table class="mt-4 w-full text-left text-sm">
    <thead>
      <tr class="border-b border-[var(--color-cream-deep)] text-[var(--color-ink-soft)]">
        <th class="py-2 font-semibold">Tamaño</th>
        <th class="py-2 text-right font-semibold">Precio</th>
      </tr>
    </thead>
    <tbody>
      {
        product.sizes.map((s) => (
          <tr class="border-b border-[var(--color-cream-deep)]/60">
            <td class="py-2">{s.label}</td>
            <td class="py-2 text-right font-semibold">{cop(s.priceCOP)}</td>
          </tr>
        ))
      }
    </tbody>
  </table>

  {
    product.extras.length > 0 && (
      <ul class="mt-4 space-y-1 text-sm">
        {product.extras.map((e) => (
          <li class="flex gap-2">
            <span aria-hidden="true" class="text-[var(--color-gold-deep)]">✦</span>
            <span>{e}</span>
          </li>
        ))}
      </ul>
    )
  }

  <div class="mt-4 flex flex-wrap gap-x-6 gap-y-1 text-sm">
    <span>⏱️ Tiempo mínimo: <strong>{product.prepDays} días</strong></span>
    {product.abono && <span>💳 {product.abono}</span>}
  </div>
  <p class="mt-3 text-xs text-[var(--color-ink-soft)]">
    Los precios no incluyen el valor del envío o domicilio.
  </p>
  <p class="mt-1 text-xs text-[var(--color-ink-soft)]">
    Medios de pago: Nequi 3022651859 · Bancolombia (Llave @fonseca9180)
  </p>
</div>
