---
import { Image } from "astro:assets";
import type { Product } from "../data/products";
import { cop } from "../consts";
import { heroImage } from "../data/images";
interface Props {
  product: Product;
}
const { product } = Astro.props;
const img = heroImage(product.slug);
---
<a href={`/${product.slug}/`} class="card group block transition-transform hover:-translate-y-1">
  {
    img && (
      <div class="aspect-[4/5] overflow-hidden bg-[var(--color-cream-deep)]">
        <Image
          src={img}
          alt={`${product.name} — Luciptera`}
          width={500}
          height={625}
          widths={[300, 500]}
          sizes="(max-width: 640px) 50vw, 300px"
          class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
          loading="lazy"
        />
      </div>
    )
  }
  <div class="p-4">
    <h3 class="font-head text-base font-bold leading-snug">{product.shortName}</h3>
    <p class="mt-1 text-sm text-[var(--color-ink-soft)]">
      {product.fromPrice > 0 ? `Desde ${cop(product.fromPrice)}` : "Precio por WhatsApp"}
    </p>
  </div>
</a>
