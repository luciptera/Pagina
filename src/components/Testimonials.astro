---
import type { Testimonial } from "../data/testimonials";
import { BUSINESS } from "../consts";
interface Props {
  items: Testimonial[];
  title?: string;
}
const { items, title = "Lo que dicen nuestros clientes" } = Astro.props;
---
{
  items.length > 0 && (
    <section class="container-base py-10">
      <div class="flex flex-wrap items-baseline justify-between gap-2">
        <h2 class="font-head text-2xl font-bold">{title}</h2>
        <a href={BUSINESS.googleUrl} target="_blank" rel="noopener" class="text-sm underline text-[var(--color-ink-soft)]">
          ★★★★★ Reseñas reales en Google →
        </a>
      </div>
      <div class="mt-5 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {items.map((t) => (
          <figure class="card flex h-full flex-col p-5">
            <div class="text-[var(--color-gold)]" aria-label={`${t.rating} de 5 estrellas`}>
              {"★".repeat(t.rating)}<span class="text-[var(--color-cream-deep)]">{"★".repeat(5 - t.rating)}</span>
            </div>
            <blockquote class="mt-2 text-[15px]">“{t.text}”</blockquote>
            <figcaption class="mt-3 text-sm font-semibold">
              {t.name} <span class="font-normal text-[var(--color-ink-soft)]">· {t.source}</span>
            </figcaption>
          </figure>
        ))}
      </div>
    </section>
  )
}
