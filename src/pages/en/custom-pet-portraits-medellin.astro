---
import { Image } from "astro:assets";
import Layout from "../../layouts/Layout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import WhatsAppCTA from "../../components/WhatsAppCTA.astro";
import { productImages, heroImage } from "../../data/images";
import { serviceSchema, breadcrumbList, faqPage } from "../../lib/schema";

const url = new URL(Astro.url.pathname, Astro.site).href;
const hero = heroImage("retratos-de-mascotas");
const gallery = productImages("retratos-de-mascotas").slice(1, 5);
const waMsg = "Hi Luciptera 🐾 I'd like a custom pet portrait";
const crumbs = [{ name: "Home", href: "/en/" }, { name: "Custom pet portraits", href: Astro.url.pathname }];

const faqs = [
  { question: "How do I order a pet portrait?", answer: "Send us your pet's photo on WhatsApp. We confirm the size, price and timeline, you pay a deposit, and we hand-paint it. Canvas portraits take about 15 days plus shipping.", scope: "global" as const },
  { question: "Do you ship internationally?", answer: "Yes. We deliver locally in Medellín and ship worldwide; international shipping is quoted by destination. We also do memorial portraits to honor a pet that has passed.", scope: "global" as const },
];

const jsonLd = [
  serviceSchema("Custom hand-painted pet portraits", "Hand-painted dog and cat portraits on canvas from your photo, made in Medellín, Colombia. Local delivery and worldwide shipping.", url),
  breadcrumbList(crumbs.map((c) => ({ name: c.name, url: new URL(c.href, Astro.site).href }))),
  faqPage(faqs),
];
---

<Layout
  title="Custom Pet Portraits Hand-Painted in Medellín | Luciptera"
  description="Custom hand-painted pet portraits from your photo, made in Medellín, Colombia. Dogs, cats and memorial portraits on canvas. Local delivery + worldwide shipping. Order on WhatsApp."
  lang="en"
  altHref={new URL("/retratos-de-mascotas/", Astro.site).href}
  ogImage={hero?.src}
  jsonLd={jsonLd}
>
  <Breadcrumbs items={crumbs} />
  <section class="container-base grid gap-8 py-8 md:grid-cols-2">
    <div>
      {hero && <Image src={hero} alt="Custom hand-painted pet portrait by Luciptera, Medellín" width={720} height={900} widths={[400,720]} sizes="(max-width:768px) 100vw, 480px" class="card aspect-[4/5] w-full object-cover" loading="eager" />}
    </div>
    <div class="flex flex-col justify-center">
      <h1 class="font-head text-3xl font-bold md:text-4xl">Custom pet portraits, hand-painted in Medellín</h1>
      <p class="mt-3 text-lg text-[var(--color-ink-soft)]">Turn your dog or cat's photo into a real painting on canvas, made entirely by hand. A timeless keepsake — and a heartfelt memorial for a pet that has passed.</p>
      <p class="mt-4 text-sm text-[var(--color-ink-soft)]">100% hand-painted · ~15 days · Local delivery in Medellín + worldwide shipping</p>
      <div class="mt-6"><WhatsAppCTA message={waMsg} label="Order on WhatsApp" note="Send us your favorite photo to start." /></div>
    </div>
  </section>

  {gallery.length > 0 && (
    <section class="container-base py-6">
      <h2 class="font-head text-2xl font-bold">Real examples</h2>
      <div class="mt-4 grid grid-cols-2 gap-3 sm:grid-cols-4">
        {gallery.map((img, i) => (
          <Image src={img} alt={`Hand-painted pet portrait example ${i + 1}`} width={420} height={525} widths={[260,420]} sizes="(max-width:640px) 45vw, 280px" class="card aspect-[4/5] w-full object-cover" loading="lazy" />
        ))}
      </div>
    </section>
  )}

  <section class="container-base py-8">
    <h2 class="font-head text-2xl font-bold">FAQ</h2>
    <div class="mt-4 space-y-4">
      {faqs.map((f) => (
        <div><h3 class="font-head font-bold">{f.question}</h3><p class="mt-1 text-[var(--color-ink-soft)]">{f.answer}</p></div>
      ))}
    </div>
    <div class="mt-6"><WhatsAppCTA message={waMsg} label="Order on WhatsApp" /></div>
    <p class="mt-4 text-sm text-[var(--color-ink-soft)]"><a class="underline" href="/retratos-de-mascotas/">Ver en español</a></p>
  </section>
</Layout>
